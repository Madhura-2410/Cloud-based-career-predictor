# ============================================================
# LOCAL DEVELOPMENT ENVIRONMENT
# ============================================================
ENVIRONMENT=development
DEBUG=true

# ============================================================
# BACKEND API
# ============================================================
API_TITLE=AI Skill Intelligence Platform
API_VERSION=1.0.0
API_PORT=8000
API_HOST=0.0.0.0
SECRET_KEY=dev-secret-key-12345
JWT_EXPIRATION_HOURS=24
CORS_ORIGINS=http://localhost:3000

# ============================================================
# DATABASE (Local Docker Container)
# ============================================================
SQL_SERVER=sql-database
SQL_DATABASE=ai_skill_platform_db
SQL_USERNAME=sa
SQL_PASSWORD=DevPassword123!
SQL_PORT=1433
SQLALCHEMY_DATABASE_URL=mssql+pyodbc://sa:DevPassword123!@sql-database:1433/ai_skill_platform_db?driver=ODBC+Driver+17+for+SQL+Server

# ============================================================
# FRONTEND
# ============================================================
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_AAD_AUTHORITY=https://login.microsoftonline.com/common
REACT_APP_AAD_CLIENT_ID=04b07795-8ddb-461a-bbee-02f9e1bf7b46
REACT_APP_SCOPES=api://default/.default

# ============================================================
# AZURE SERVICES (Disabled for Local Development)
# ============================================================
AZURE_TENANT_ID=disabled
AZURE_CLIENT_ID=disabled
AZURE_CLIENT_SECRET=disabled
BACKEND_AAD_CLIENT_ID=disabled
AAD_AUTHORITY=https://login.microsoftonline.com/common
AAD_SCOPES=api://default/.default

BLOB_STORAGE_ACCOUNT=disabled
BLOB_STORAGE_KEY=disabled
BLOB_CONTAINER_DATASETS=datasets
BLOB_CONTAINER_MODELS=ml-models
BLOB_CONTAINER_UPLOADS=user-uploads

KEY_VAULT_NAME=disabled
KEY_VAULT_URI=disabled

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
