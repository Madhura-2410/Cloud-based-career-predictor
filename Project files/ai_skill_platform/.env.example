# ============================================================
# AZURE SUBSCRIPTION & AUTHENTICATION
# ============================================================
AZURE_SUBSCRIPTION_ID=your-subscription-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret
AZURE_RESOURCE_GROUP=ai-skill-platform-rg
AZURE_LOCATION=eastus

# ============================================================
# AZURE ACTIVE DIRECTORY (AAD)
# ============================================================
AAD_AUTHORITY=https://login.microsoftonline.com/{AZURE_TENANT_ID}
AAD_SCOPES=api://your-api-app-id/.default
AAD_REDIRECT_URI=http://localhost:3000
FRONTEND_AAD_CLIENT_ID=your-frontend-aad-client-id
BACKEND_AAD_CLIENT_ID=your-backend-aad-client-id

# ============================================================
# AZURE SQL DATABASE
# ============================================================
SQL_SERVER=your-sql-server.database.windows.net
SQL_DATABASE=ai_skill_platform_db
SQL_USERNAME=sqladmin
SQL_PASSWORD=your-strong-password
SQL_PORT=1433
SQLALCHEMY_DATABASE_URL=mssql+pyodbc://sqladmin:your-password@your-sql-server.database.windows.net:1433/ai_skill_platform_db?driver=ODBC+Driver+17+for+SQL+Server

# ============================================================
# AZURE BLOB STORAGE
# ============================================================
BLOB_STORAGE_ACCOUNT=yourstorageaccount
BLOB_STORAGE_KEY=your-storage-account-key
BLOB_CONTAINER_DATASETS=datasets
BLOB_CONTAINER_MODELS=ml-models
BLOB_CONTAINER_UPLOADS=user-uploads
BLOB_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=your-key;EndpointSuffix=core.windows.net

# ============================================================
# AZURE MACHINE LEARNING
# ============================================================
AZURE_ML_WORKSPACE_NAME=ai-skill-ml-ws
AZURE_ML_RESOURCE_GROUP=ai-skill-platform-rg
AZURE_ML_SUBSCRIPTION_ID=your-subscription-id
AZURE_ML_COMPUTE_TARGET=cpu-cluster

# ============================================================
# AZURE KEY VAULT
# ============================================================
KEY_VAULT_NAME=ai-skill-vault
KEY_VAULT_URI=https://ai-skill-vault.vault.azure.net/
KEY_VAULT_SECRET_NAME=db-connection-string

# ============================================================
# AZURE FUNCTIONS
# ============================================================
FUNCTIONS_WORKER_RUNTIME=python
AZURE_FUNCTIONS_ENVIRONMENT=development
FUNCTION_APP_NAME=ai-skill-functions
FUNCTION_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=your-key;EndpointSuffix=core.windows.net

# ============================================================
# AZURE MONITOR & APPLICATION INSIGHTS
# ============================================================
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-instrumentation-key;IngestionEndpoint=https://eastus-8.in.applicationinsights.azure.com/;LiveEndpoint=https://eastus.livediagnostics.monitor.azure.com/
APPLICATIONINSIGHTS_INSTRUMENTATION_KEY=your-instrumentation-key

# ============================================================
# BACKEND API
# ============================================================
API_TITLE=AI Skill Intelligence Platform
API_VERSION=1.0.0
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=True
SECRET_KEY=your-secret-key-for-jwt-tokens
JWT_EXPIRATION_HOURS=24

# ============================================================
# FRONTEND
# ============================================================
REACT_APP_API_URL=http://localhost:8000/api
REACT_APP_AAD_AUTHORITY=https://login.microsoftonline.com/{AZURE_TENANT_ID}
REACT_APP_AAD_CLIENT_ID=your-frontend-aad-client-id
REACT_APP_SCOPES=api://your-api-app-id/.default

# ============================================================
# DATA INGESTION
# ============================================================
DATASET_INDEED_POSTINGS=ai_jobs_market_2025_2026.csv
DATASET_AI_JOBS=ai_jobs_market_2025_2026.csv
DATASET_RESUME=resume_data.csv
DATASET_COMPANIES=companies.csv

# ============================================================
# LOGGING & ENVIRONMENT
# ============================================================
LOG_LEVEL=INFO
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
